{
  "name": "plume-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* run build",
    "dev": "pnpm -r --parallel --filter=./packages/* --filter=./examples/* run dev",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write . && eslint . --fix",
    "clean": "pnpm -r exec rm -rf dist node_modules/.cache && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}
